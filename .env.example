# Nepal OSINT Platform v5 - Environment Configuration
# Copy this file to backend-v5/.env and fill in the values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL (async driver for FastAPI)
DATABASE_URL=postgresql+asyncpg://nepal_osint:nepal_osint_dev@localhost:5433/nepal_osint_v5
POSTGRES_PASSWORD=nepal_osint_dev

# Redis
REDIS_URL=redis://localhost:6380/0

# =============================================================================
# CLAUDE API (Optional - for Haiku analysis)
# =============================================================================
# Get your API key from: https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-your-key-here

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment (development | production)
APP_ENV=development

# Debug mode (set to false in production)
DEBUG=true

# CORS allowed origins (comma-separated)
# Supports CORS_ORIGINS or legacy ALLOWED_ORIGINS
CORS_ORIGINS=http://localhost:5173,https://osintnepal.com

# JWT auth (REQUIRED in production)
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_STRONG_SECRET_KEY

# Unified candidate read mode:
# - db_primary_json_fallback (default)
# - db_only
# - json_only
UNIFIED_CANDIDATE_READ_MODE=db_primary_json_fallback

# =============================================================================
# QUICK START
# =============================================================================
# 1. Copy this file to backend-v5/.env
# 2. Start services: cd backend-v5 && docker compose up -d
# 3. Run migrations: alembic upgrade head
# 4. Start backend: uvicorn app.main:app --reload --port 8001
# 5. Start frontend: cd frontend && npm run dev
